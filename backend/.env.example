# Copy this file to .env and fill in the values for local development.
# Never commit .env to git.

# MongoDB connection string
# Local:      mongodb://localhost:27017
# Atlas:      mongodb+srv://USER:PASSWORD@cluster.mongodb.net
MONGO_URI=mongodb://localhost:27017

# Database name
DB_NAME=studyswap

# JWT secret — use any long random string locally
# Generate a strong one for production: openssl rand -hex 32
JWT_SECRET=local-dev-secret-change-in-production

# JWT settings (these rarely need to change)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated allowed CORS origins
# Local: keep as-is
# Production: set to your Vercel frontend URL on Render dashboard
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
